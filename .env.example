# ───────────────────────────────────────────────
# ОБОВ'ЯЗКОВО заповнити:
# ───────────────────────────────────────────────

# Токен бота (discord.com/developers/applications → Bot → Token)
DISCORD_TOKEN=

# Application ID (discord.com/developers/applications → General Information)
CLIENT_ID=

# ───────────────────────────────────────────────
# НЕОБОВ'ЯЗКОВО:
# ───────────────────────────────────────────────

# ID сервера для швидкого деплою команд (рекомендовано)
# Без нього команди реєструються глобально (~1 год)
# ПКМ на сервері в Discord → Copy Server ID
GUILD_ID=

# Spotify (для відтворення Spotify посилань)
# developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube cookies для обходу вікових обмежень
# (розширення "Get cookies.txt LOCALLY" → youtube.com)
YOUTUBE_COOKIE=
